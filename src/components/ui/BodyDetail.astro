---
import { getCollection } from 'astro:content';
import type { Body } from '../../data/planets';

interface Props {
  body: Body;
}

const { body } = Astro.props;

// 0xRRGGBB number → "#rrggbb" so we can use the body's scene color as a subtle
// accent in the (static, zero-JS) detail page.
const accent = `#${body.color.toString(16).padStart(6, '0')}`;

const statusLabels: Record<string, string> = {
  active: 'Active',
  shipped: 'Shipped',
  prototype: 'Prototype',
  wip: 'WIP',
  archived: 'Archived',
};

// Pull every project tagged for this category and order them: featured first,
// then newest year, then alphabetical.
const projects = (await getCollection('projects'))
  .filter((entry) => entry.data.planet === body.name)
  .sort((a, b) => {
    if (!!a.data.featured !== !!b.data.featured) {
      return a.data.featured ? -1 : 1;
    }
    if ((a.data.year ?? 0) !== (b.data.year ?? 0)) {
      return (b.data.year ?? 0) - (a.data.year ?? 0);
    }
    return a.data.title.localeCompare(b.data.title);
  });
---

<!-- Full-screen, zero-JS category page for one celestial body. Lists the
     projects that belong to this category as a responsive grid of cards. -->
<div class="planet-detail-view" style={`--accent: ${accent};`}>
  <a href="/" class="back-to-solar-btn">
    <i class="fas fa-arrow-left"></i> Back to Solar System
  </a>

  <div class="detail-shell">
    <header class="detail-header">
      <p class="detail-eyebrow">{body.type}</p>
      <h1 class="detail-title">{body.name}</h1>
      <p class="detail-tagline">{body.desc}</p>
    </header>

    {
      projects.length > 0 ? (
        <ul class="project-grid">
          {projects.map((entry) => (
            <li>
              <a class="project-card" href={`/projects/${entry.id}`}>
                <div class="project-card-top">
                  <h2 class="project-card-title">{entry.data.title}</h2>
                  {entry.data.status && (
                    <span class={`status-badge status-${entry.data.status}`}>
                      {statusLabels[entry.data.status] ?? entry.data.status}
                    </span>
                  )}
                </div>
                <p class="project-card-summary">{entry.data.summary}</p>
                {entry.data.tags && entry.data.tags.length > 0 && (
                  <ul class="tag-list">
                    {entry.data.tags.map((tag) => (
                      <li class="tag-pill">{tag}</li>
                    ))}
                  </ul>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="empty-state">
          <i class="fas fa-satellite-dish"></i>
          <p class="empty-state-title">More landing here soon.</p>
          <p class="empty-state-sub">
            This category is still taking shape — work in progress.
          </p>
        </div>
      )
    }
  </div>
</div>
